{
  "name": "alerts",
  "version": "1.0.0",
  "description": "Alert service",
  "dependencies": {
    "@apollo/federation": "0.38.1",
    "@apollo/server": "^4.12.2",
    "@as-integrations/fastify": "^3.1.0",
    "@aws-sdk/client-ses": "^3.980.0",
    "@databases/mysql": "7.0.0",
    "@fastify/cookie": "^11.0.2",
    "@gratheon/log-lib": "^2.2.7",
    "axios": "1.13.6",
    "cross-fetch": "4.0.0",
    "fastify": "5.7.4",
    "fastify-raw-body": "3.2.0",
    "graphql": "16.13.0",
    "mysql2": "3.16.2",
    "sha1": "1.1.1",
    "twilio": "^5.12.0",
    "uuid": "^13.0.0"
  },
  "scripts": {
    "build": "tsc -p ./src/config/tsconfig.json",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "./node_modules/.bin/jest --config ./test/unit/jest.config.js --detectOpenHandles --forceExit",
    "test:integration": "sh -c 'set -e; npm run test:docker:start; cleanup() { npm run test:docker:stop; }; trap cleanup EXIT; for i in $(seq 1 30); do if docker compose -f docker-compose.test.yml exec -T mysql mysqladmin ping -h localhost --silent; then break; fi; if [ \"$i\" -eq 30 ]; then echo \"MySQL did not become ready\"; exit 1; fi; sleep 2; done; for i in $(seq 1 30); do if curl -fsS http://localhost:4560/health >/dev/null; then break; fi; if [ \"$i\" -eq 30 ]; then echo \"alerts service did not become ready\"; exit 1; fi; sleep 2; done; npm run build; ENV_ID=dev ./node_modules/.bin/jest --config ./test/integration/jest.config.json --detectOpenHandles --forceExit'",
    "test:integration:ci": "npm run build && TEST_API_HOST=localhost ./node_modules/.bin/jest --config ./test/integration/jest.config.ci.json --detectOpenHandles --forceExit",
    "test:manual": "npm run build && ENV_ID=dev ./node_modules/.bin/jest --config ./test/manual-tests/jest.config.json --detectOpenHandles --forceExit",
    "test:docker": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit",
    "test:docker:start": "docker compose -f docker-compose.test.yml up -d",
    "test:docker:stop": "docker compose -f docker-compose.test.yml down -v",
    "dev": "ENV_ID=dev nodemon app/alerts.js",
    "start": "ENV_ID=prod node app/alerts.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gratheon/alerts.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gratheon/alerts/issues"
  },
  "homepage": "https://github.com/gratheon/alerts#readme",
  "devDependencies": {
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "node-fetch": "3.3.2",
    "nodemon": "3.1.11",
    "ts-jest": "29.2.5",
    "tsc-watch": "6.0.4",
    "typescript": "5.2.2"
  },
  "overrides": {
    "fast-xml-parser": "^5.4.1",
    "cookie": "^0.7.0",
    "form-data": "^4.0.0",
    "qs": "^6.15.0",
    "tough-cookie": "^4.1.3"
  }
}
