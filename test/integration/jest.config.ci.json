{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "testMatch": [
    "<rootDir>/api.test.ts",
    "<rootDir>/auth-validation.test.ts",
    "<rootDir>/config.test.ts",
    "<rootDir>/cross-channel.test.ts"
  ],
  "testTimeout": 60000,
  "maxWorkers": 1,
  "collectCoverageFrom": ["<rootDir>/../../src/**/*.ts"],
  "coveragePathIgnorePatterns": ["/node_modules/", "/test/", "/.test.ts$/"]
}
